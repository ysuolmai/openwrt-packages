{
	"luci-app-moontvplus": {
		"description": "Grant access to MoonTVPlus management",
		"read": {
			"uci": [ "moontvplus" ],
			"ubus": {
				"luci.moontvplus": [ "status", "logs", "core_update_status" ],
				"service": [ "list" ]
			}
		},
		"write": {
			"uci": [ "moontvplus" ],
			"ubus": {
				"luci.moontvplus": [ "control", "core_update_start" ],
				"uci": [ "apply" ]
			}
		}
	}
}
