#!/bin/sh /etc/rc.common

START=81
STOP=19
USE_PROCD=1

CONFIG_FILE=/var/etc/nginx-proxy.conf
GENERATOR=/usr/libexec/nginx-proxy-generate

generate_config() {
	local candidate="$CONFIG_FILE.new"

	mkdir -p /var/etc /var/lib/nginx /var/lib/nginx-proxy \
		/var/log/nginx /var/log/nginx-proxy
	"$GENERATOR" "$candidate" || return 1
	/usr/sbin/nginx -t -q -c "$candidate" || return 1
	mv "$candidate" "$CONFIG_FILE"
}

start_service() {
	local enabled
	config_load nginx_proxy
	config_get_bool enabled main enabled 0
	[ "$enabled" -eq 1 ] || return 0

	generate_config || return 1

	procd_open_instance
	procd_set_param command /usr/sbin/nginx -c "$CONFIG_FILE" -g 'daemon off;'
	procd_set_param stdout 1
	procd_set_param stderr 1
	procd_set_param respawn 3600 5 5
	procd_set_param file /etc/config/nginx_proxy "$CONFIG_FILE"
	procd_close_instance
}

reload_service() {
	generate_config || return 1
	procd_send_signal nginx-proxy '*' HUP
}

service_triggers() {
	procd_add_reload_trigger nginx_proxy
}
