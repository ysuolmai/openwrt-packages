#!/bin/sh

set -e

. /lib/functions.sh
. /lib/functions/network.sh

OUTPUT="$1"
BODY="$OUTPUT.body"
ALLOW="$OUTPUT.allow"
NAMES="$OUTPUT.names"
ROUTES=0
FIRST_CERT=
FIRST_KEY=
MANAGEMENT_HTTPS=0
MANAGEMENT_CERT=
MANAGEMENT_KEY=
HTTP_PORT=80
HTTPS_PORT=443

fail() {
	echo "nginx-proxy: $*" >&2
	rm -f "$BODY" "$ALLOW" "$NAMES" "$OUTPUT"
	exit 1
}

valid_port() {
	case "$1" in
		''|*[!0-9]*) return 1 ;;
	esac
	[ "$1" -ge 1 ] && [ "$1" -le 65535 ]
}

valid_domain() {
	echo "$1" | grep -Eq '^(\*\.)?([A-Za-z0-9]([A-Za-z0-9-]{0,61}[A-Za-z0-9])?\.)+[A-Za-z]{2,63}$'
}

valid_backend() {
	echo "$1" | grep -Eq '^([A-Za-z0-9]([A-Za-z0-9.-]*[A-Za-z0-9])?|[0-9A-Fa-f:]+)$'
}

valid_path() {
	echo "$1" | grep -Eq '^/(etc/nginx-proxy|etc/acme|etc/ssl|etc/luci-uploads)/[A-Za-z0-9_./@+:-]+$' &&
		[ -r "$1" ]
}

emit_allow_network() {
	local network="$1" subnets subnet network_addr prefix addresses address

	network_get_subnets subnets "$network" 2>/dev/null || subnets=
	for subnet in $subnets; do
		network_addr="$(/bin/ipcalc.sh "$subnet" | sed -n 's/^NETWORK=//p')"
		prefix="$(/bin/ipcalc.sh "$subnet" | sed -n 's/^PREFIX=//p')"
		[ -n "$network_addr" ] && [ -n "$prefix" ] &&
			echo "        allow $network_addr/$prefix;" >> "$ALLOW"
	done

	network_get_subnets6 subnets "$network" 2>/dev/null || subnets=
	for subnet in $subnets; do
		echo "        allow $subnet;" >> "$ALLOW"
	done

	network_get_ipaddrs addresses "$network" 2>/dev/null || addresses=
	for address in $addresses; do
		echo "$address" >> "$NAMES"
	done

	network_get_ipaddrs6 addresses "$network" 2>/dev/null || addresses=
	for address in $addresses; do
		echo "[$address]" >> "$NAMES"
	done
}

emit_proxy_headers() {
	cat >> "$1" <<-'EOF'
            proxy_http_version 1.1;
            proxy_set_header Host $host;
            proxy_set_header X-Real-IP $remote_addr;
            proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
            proxy_set_header X-Forwarded-Proto $scheme;
            proxy_set_header Upgrade $http_upgrade;
            proxy_set_header Connection "upgrade";
            proxy_read_timeout 3600s;
            proxy_send_timeout 3600s;
	EOF
}

emit_proxy() {
	local section="$1" enabled domain scheme backend port cert key cert_id verify_tls target

	config_get_bool enabled "$section" enabled 1
	[ "$enabled" -eq 1 ] || return 0
	config_get domain "$section" domain
	config_get scheme "$section" scheme http
	config_get backend "$section" backend
	config_get port "$section" port
	config_get cert_id "$section" cert_id
	case "$cert_id" in
		''|*[!A-Za-z0-9_]*) cert_id= ;;
	esac
	cert="/etc/nginx-proxy/certs/$cert_id.cert.pem"
	key="/etc/nginx-proxy/certs/$cert_id.key"
	if [ -z "$cert_id" ] || [ ! -r "$cert" ]; then
		config_get cert "$section" certificate
	fi
	if [ -z "$cert_id" ] || [ ! -r "$key" ]; then
		config_get key "$section" private_key
	fi
	config_get_bool verify_tls "$section" verify_tls 0

	valid_domain "$domain" || fail "invalid domain in $section"
	case "$scheme" in http|https) ;; *) fail "invalid backend scheme in $section" ;; esac
	valid_backend "$backend" || fail "invalid backend address in $section"
	valid_port "$port" || fail "invalid backend port in $section"
	valid_path "$cert" || fail "certificate is missing or outside an allowed directory in $section"
	valid_path "$key" || fail "private key is missing or outside an allowed directory in $section"

	case "$backend" in
		*:*) target="[$backend]" ;;
		*) target="$backend" ;;
	esac

	[ -n "$FIRST_CERT" ] || {
		FIRST_CERT="$cert"
		FIRST_KEY="$key"
	}

	cat >> "$BODY" <<-EOF

    server {
        listen $HTTP_PORT;
        listen [::]:$HTTP_PORT;
        server_name $domain;
        return 308 https://\$host:$HTTPS_PORT\$request_uri;
    }

    server {
        listen $HTTPS_PORT ssl;
        listen [::]:$HTTPS_PORT ssl;
        server_name $domain;
        ssl_certificate $cert;
        ssl_certificate_key $key;
        ssl_protocols TLSv1.2 TLSv1.3;
        location / {
            proxy_pass $scheme://$target:$port;
EOF
	emit_proxy_headers "$BODY"
	if [ "$scheme" = https ]; then
		echo '            proxy_ssl_server_name on;' >> "$BODY"
		echo "            proxy_ssl_name $backend;" >> "$BODY"
		[ "$verify_tls" -eq 1 ] || echo '            proxy_ssl_verify off;' >> "$BODY"
	fi
	cat >> "$BODY" <<-'EOF'
        }
    }
	EOF
	ROUTES=$((ROUTES + 1))
}

rm -f "$BODY" "$ALLOW" "$NAMES" "$OUTPUT"
touch "$BODY" "$ALLOW" "$NAMES"
network_flush_cache

config_load nginx_proxy
config_get HTTP_PORT main management_http_port 80
config_get HTTPS_PORT main management_https_port 443
config_get_bool MANAGEMENT_HTTPS main management_https 0
MANAGEMENT_CERT=/etc/nginx-proxy/certs/main.cert.pem
MANAGEMENT_KEY=/etc/nginx-proxy/certs/main.key
if [ ! -r "$MANAGEMENT_CERT" ]; then
	config_get MANAGEMENT_CERT main management_certificate
fi
if [ ! -r "$MANAGEMENT_KEY" ]; then
	config_get MANAGEMENT_KEY main management_private_key
fi

valid_port "$HTTP_PORT" || fail 'invalid management HTTP port'
valid_port "$HTTPS_PORT" || fail 'invalid HTTPS port'
[ "$HTTP_PORT" != "$HTTPS_PORT" ] || fail 'HTTP and HTTPS ports must differ'

config_list_foreach main management_network emit_allow_network
[ -s "$ALLOW" ] || fail 'no address found for a management network'
[ -s "$NAMES" ] || fail 'no IP address found for a management network'

if [ "$MANAGEMENT_HTTPS" -eq 1 ]; then
	valid_path "$MANAGEMENT_CERT" || fail 'management certificate is missing or outside an allowed directory'
	valid_path "$MANAGEMENT_KEY" || fail 'management private key is missing or outside an allowed directory'
fi

config_foreach emit_proxy reverse_proxy

cat > "$OUTPUT" <<-EOF
worker_processes 1;
pid /var/run/nginx-proxy.pid;
error_log stderr warn;

events { worker_connections 512; }

http {
    include /etc/nginx/mime.types;
    default_type application/octet-stream;
    server_names_hash_bucket_size 64;
    access_log off;
    sendfile on;
    client_max_body_size 128m;

    server {
        listen $HTTP_PORT default_server;
        listen [::]:$HTTP_PORT default_server;
        server_name _;
        return 444;
    }

    server {
        listen $HTTP_PORT;
        listen [::]:$HTTP_PORT;
        server_name $(tr '\n' ' ' < "$NAMES");
EOF
cat "$ALLOW" >> "$OUTPUT"
cat >> "$OUTPUT" <<-'EOF'
        deny all;
        error_page 403 = @drop;
        location @drop { return 444; }
        location / {
            proxy_pass http://127.0.0.1:8080;
	EOF
emit_proxy_headers "$OUTPUT"
cat >> "$OUTPUT" <<-'EOF'
        }
    }
	EOF

if [ "$MANAGEMENT_HTTPS" -eq 1 ]; then
	cat >> "$OUTPUT" <<-EOF

    server {
        listen $HTTPS_PORT ssl default_server;
        listen [::]:$HTTPS_PORT ssl default_server;
        server_name _;
        ssl_certificate $MANAGEMENT_CERT;
        ssl_certificate_key $MANAGEMENT_KEY;
        ssl_protocols TLSv1.2 TLSv1.3;
        return 444;
    }

    server {
        listen $HTTPS_PORT ssl;
        listen [::]:$HTTPS_PORT ssl;
        server_name $(tr '\n' ' ' < "$NAMES");
        ssl_certificate $MANAGEMENT_CERT;
        ssl_certificate_key $MANAGEMENT_KEY;
        ssl_protocols TLSv1.2 TLSv1.3;
EOF
	cat "$ALLOW" >> "$OUTPUT"
	cat >> "$OUTPUT" <<-'EOF'
        deny all;
        error_page 403 = @drop;
        location @drop { return 444; }
        location / {
            proxy_pass http://127.0.0.1:8080;
	EOF
	emit_proxy_headers "$OUTPUT"
	cat >> "$OUTPUT" <<-'EOF'
        }
    }
	EOF
elif [ "$ROUTES" -gt 0 ]; then
	cat >> "$OUTPUT" <<-EOF

    server {
        listen $HTTPS_PORT ssl default_server;
        listen [::]:$HTTPS_PORT ssl default_server;
        server_name _;
        ssl_certificate $FIRST_CERT;
        ssl_certificate_key $FIRST_KEY;
        return 444;
    }
EOF
fi

cat "$BODY" >> "$OUTPUT"
echo '}' >> "$OUTPUT"
rm -f "$BODY" "$ALLOW" "$NAMES"
