config init
	option stdout 1
	option stderr 1
	option user root
	option group root
	option respawn 1
#	OS environments pass to frp for config file template, see
#	https://github.com/fatedier/frp#configuration-file-template
#	list env 'ENV_NAME=value'
#	TOML fragments appended to the generated configuration.
#	list conf_inc '/etc/frp/frpc.d/custom.toml'

config conf 'common'
	option enabled 0
	option server_addr 127.0.0.1
	option server_port 7000
#	List options with name="_" will be directly appended as TOML.
#	list _ '# key = "value"'

config conf 'ssh'
	option type tcp
	option local_ip 127.0.0.1
	option local_port 22
	option remote_port 6000
